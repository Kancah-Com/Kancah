RewriteEngine On
RewriteBase /

# 1. Jika URL-nya kancah.com/sesuatu, arahkan ke post.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)$ post.html?slug=$1 [L,QSA]

# 2. Jika mengakses file .html langsung, hilangkan ekstensinya
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.html [L]
